# Copia este archivo a .env y completa los valores
DATABASE_URL=postgresql+asyncpg://gvi:gvi_pass@localhost:5432/gvi
JWT_SECRET=cambia-esto-por-una-cadena-aleatoria-larga
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:8080,https://gvi.namu-li.com
ADMIN_EMAIL=admin@gvi.com
ADMIN_PASSWORD=Admin123!

# URL publica del frontend (arma el link del email de reset)
FRONTEND_URL=https://gvi.namu-li.com

# SMTP (Gmail con app password). Dejar vacio para deshabilitar envio.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM=tu-correo@gmail.com
SMTP_FROM_NAME=GesVentas
RESET_TOKEN_EXPIRE_MINUTES=60
